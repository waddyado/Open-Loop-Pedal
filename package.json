{
  "name": "open-loop-pedal",
  "version": "0.1.0",
  "description": "Desktop looping and pedalboard application",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:electron": "node scripts/build-electron.mjs",
    "build": "npm run build:electron && vite build",
    "preview": "vite preview",
    "start": "cross-env VITE_DEV_SERVER_URL= electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "esbuild": "^0.24.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
